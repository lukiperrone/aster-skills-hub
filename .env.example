# Aster Skills Hub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# === Deposit Script (deposit.mjs) ===
# Wallet private key for signing deposit transactions.
# Format: 0x followed by 64 hex characters (32 bytes).
# SECURITY: Use a dedicated deposit wallet, not your main wallet.
# Consider using a hardware wallet signer or secret manager (Vault, 1Password CLI, AWS Secrets Manager).
ASTER_DEPOSIT_PRIVATE_KEY=

# === Balance Script (balance.mjs) ===
# Public wallet address for read-only balance queries.
# The balance script does NOT need a private key.
ASTER_WALLET_ADDRESS=

# === RPC Endpoints (recommended for production) ===
# Public RPCs are used as fallback but have no SLA, no auth, and can be manipulated.
# Use private RPCs from Alchemy, Infura, QuickNode, or your own node.
ETH_RPC_URL=
BSC_RPC_URL=
ARBITRUM_RPC_URL=

# === Treasury Whitelist (development only) ===
# Set to "true" to disable treasury address whitelist validation.
# WARNING: Only use this in development/testing. Never in production.
# ASTER_TREASURY_WHITELIST_DISABLED=true
